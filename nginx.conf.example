# Primary domain: techaks.ru

# Redirect www -> apex
server {
    listen 80;
    listen [::]:80;
    server_name techaks.ru www.techaks.ru xn--80ajq2abt.xn--p1ai www.xn--80ajq2abt.xn--p1ai;
    return 301 https://techaks.ru$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name www.techaks.ru xn--80ajq2abt.xn--p1ai www.xn--80ajq2abt.xn--p1ai;

    ssl_certificate /etc/letsencrypt/live/techaks.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/techaks.ru/privkey.pem;

    return 301 https://techaks.ru$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name techaks.ru;

    ssl_certificate /etc/letsencrypt/live/techaks.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/techaks.ru/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
